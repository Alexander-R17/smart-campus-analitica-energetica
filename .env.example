# Smart Campus Supabase Cloud
# Copia este archivo como .env si tu hosting lo soporta, o pega valores en backend/app/config/ExternalServices.php solo para demo local.

SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_API_KEY=PEGAR_SUPABASE_ANON_O_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=public

COLAB_API_URL=https://TU_URL_NGROK.ngrok-free.app
COLAB_INPUT_MODE=backend_export

GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec
GOOGLE_SHEETS_TOKEN=CAMBIAR_TOKEN_SIMPLE
LOOKER_STUDIO_URL=https://lookerstudio.google.com/reporting/TU_REPORTE

KEEP_LOCAL_UPLOAD_BACKUP=false
